<?xml version="1.0" encoding="utf-8"?>
<form>
    <fields name="filter">
        <field name="search" type="text" label="COM_LOGINGUARD_FILTER_BLOCKEDIPS_SEARCH_LABEL" description="COM_LOGINGUARD_FILTER_BLOCKEDIPS_SEARCH_DESC" hint="COM_LOGINGUARD_BLOCKEDIPS_SEARCH_PLACEHOLDER" />
        <field name="enabled" type="list" label="COM_LOGINGUARD_FILTER_ENABLED" onchange="this.form.submit();">
            <option value="">JOPTION_SELECT_PUBLISHED</option>
            <option value="1">COM_LOGINGUARD_BLOCKEDIPS_ENABLED</option>
            <option value="0">COM_LOGINGUARD_BLOCKEDIPS_DISABLED</option>
        </field>
        <field name="block_type" type="list" label="COM_LOGINGUARD_FILTER_BLOCK_TYPE" onchange="this.form.submit();">
            <option value="">COM_LOGINGUARD_FILTER_BLOCK_TYPE</option>
            <option value="temporary">COM_LOGINGUARD_BLOCK_TYPE_TEMPORARY</option>
            <option value="permanent">COM_LOGINGUARD_BLOCK_TYPE_PERMANENT</option>
        </field>
        <field name="scope" type="list" label="COM_LOGINGUARD_FILTER_SCOPE" onchange="this.form.submit();">
            <option value="">COM_LOGINGUARD_FILTER_SCOPE</option>
            <option value="all">COM_LOGINGUARD_SCOPE_ALL</option>
            <option value="frontend">COM_LOGINGUARD_SCOPE_FRONTEND</option>
            <option value="backend">COM_LOGINGUARD_SCOPE_BACKEND</option>
        </field>
    </fields>
    <fields name="list">
        <field name="fullordering" type="list" label="JGLOBAL_SORT_BY" onchange="this.form.submit();" default="created DESC">
            <option value="created DESC">COM_LOGINGUARD_HEADING_DATETIME_DESC</option>
            <option value="created ASC">COM_LOGINGUARD_HEADING_DATETIME_ASC</option>
            <option value="ip_address ASC">COM_LOGINGUARD_HEADING_IP_ADDRESS_ASC</option>
            <option value="ip_address DESC">COM_LOGINGUARD_HEADING_IP_ADDRESS_DESC</option>
            <option value="enabled ASC">COM_LOGINGUARD_HEADING_ENABLED_ASC</option>
            <option value="enabled DESC">COM_LOGINGUARD_HEADING_ENABLED_DESC</option>
            <option value="block_type ASC">COM_LOGINGUARD_HEADING_BLOCK_TYPE_ASC</option>
            <option value="block_type DESC">COM_LOGINGUARD_HEADING_BLOCK_TYPE_DESC</option>
        </field>
        <field name="limit" type="limitbox" label="JGLOBAL_LIST_LIMIT" default="20" onchange="this.form.submit();" />
    </fields>
</form>
