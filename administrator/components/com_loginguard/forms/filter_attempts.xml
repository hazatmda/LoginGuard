<?xml version="1.0" encoding="utf-8"?>
<form>
    <fields name="filter">
        <field
            name="search"
            type="text"
            inputmode="search"
            label="COM_LOGINGUARD_FILTER_SEARCH_LABEL"
            description="COM_LOGINGUARD_FILTER_SEARCH_DESC"
            hint="COM_LOGINGUARD_SEARCH_PLACEHOLDER"
        />
        <field
            name="status"
            type="list"
            label="COM_LOGINGUARD_FILTER_STATUS"
            onchange="this.form.submit();"
            default=""
            validate="options"
        >
            <option value="">JOPTION_SELECT_STATUS</option>
            <option value="success">COM_LOGINGUARD_STATUS_SUCCESS</option>
            <option value="failed">COM_LOGINGUARD_STATUS_FAILED</option>
        </field>
        <field
            name="where_at"
            type="list"
            label="COM_LOGINGUARD_FILTER_WHERE"
            onchange="this.form.submit();"
            default=""
            validate="options"
        >
            <option value="">COM_LOGINGUARD_FILTER_WHERE</option>
            <option value="site">COM_LOGINGUARD_WHERE_SITE</option>
            <option value="administrator">COM_LOGINGUARD_WHERE_ADMINISTRATOR</option>
        </field>
    </fields>
    <fields name="list">
        <field
            name="fullordering"
            type="list"
            label="JGLOBAL_SORT_BY"
            onchange="this.form.submit();"
            default="created DESC"
            validate="options"
        >
            <option value="">JGLOBAL_SORT_BY</option>
            <option value="id ASC">JGRID_HEADING_ID_ASC</option>
            <option value="id DESC">JGRID_HEADING_ID_DESC</option>
            <option value="ip_address ASC">COM_LOGINGUARD_HEADING_IP_ADDRESS_ASC</option>
            <option value="ip_address DESC">COM_LOGINGUARD_HEADING_IP_ADDRESS_DESC</option>
            <option value="name ASC">COM_LOGINGUARD_HEADING_NAME_ASC</option>
            <option value="name DESC">COM_LOGINGUARD_HEADING_NAME_DESC</option>
            <option value="username ASC">COM_LOGINGUARD_HEADING_USERNAME_ASC</option>
            <option value="username DESC">COM_LOGINGUARD_HEADING_USERNAME_DESC</option>
            <option value="status ASC">COM_LOGINGUARD_HEADING_STATUS_ASC</option>
            <option value="status DESC">COM_LOGINGUARD_HEADING_STATUS_DESC</option>
            <option value="created ASC">COM_LOGINGUARD_HEADING_DATETIME_ASC</option>
            <option value="created DESC">COM_LOGINGUARD_HEADING_DATETIME_DESC</option>
            <option value="country ASC">COM_LOGINGUARD_HEADING_COUNTRY_ASC</option>
            <option value="country DESC">COM_LOGINGUARD_HEADING_COUNTRY_DESC</option>
            <option value="browser ASC">COM_LOGINGUARD_HEADING_BROWSER_ASC</option>
            <option value="browser DESC">COM_LOGINGUARD_HEADING_BROWSER_DESC</option>
            <option value="operating_system ASC">COM_LOGINGUARD_HEADING_OS_ASC</option>
            <option value="operating_system DESC">COM_LOGINGUARD_HEADING_OS_DESC</option>
            <option value="where_at ASC">COM_LOGINGUARD_HEADING_WHERE_ASC</option>
            <option value="where_at DESC">COM_LOGINGUARD_HEADING_WHERE_DESC</option>
        </field>
        <field
            name="limit"
            type="limitbox"
            label="JGLOBAL_LIST_LIMIT"
            default="25"
            onchange="this.form.submit();"
        />
    </fields>
</form>
